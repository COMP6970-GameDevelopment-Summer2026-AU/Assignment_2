# ══════════════════════════════════════════════════════════════
# .gitignore — PuKu's Adventure (Unity 6 Project)
# ══════════════════════════════════════════════════════════════

# ── Unity generated folders ───────────────────────────────────
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# ── Unity asset database (auto-generated) ─────────────────────
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ── Generated tile assets (rebuilt by CartographySceneBuilder) ─
Assets/Tiles/Cartography/

# ── VS / Rider project files ──────────────────────────────────
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ── OS generated ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── JetBrains Rider ───────────────────────────────────────────
.idea/
*.riderproject

# ── Visual Studio Code ────────────────────────────────────────
.vscode/
.vsconfig

# ── Build output ──────────────────────────────────────────────
/[Bb]uild/
/[Bb]uilds/
/[Pp]ackages/
*.apk
*.aab
*.unitypackage
*.app

# ── Crashes ───────────────────────────────────────────────────
sysinfo.txt
Crashes/

# ── Asset Store tools ─────────────────────────────────────────
/[Aa]ssets/[Aa]sset[Ss]tore[Tt]ools/

# ── TextMeshPro settings (keep source, ignore generated) ──────
/[Aa]ssets/TextMesh*/

# ── Addressables ──────────────────────────────────────────────
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*
!/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*.json

# ── StreamingAssets generated ─────────────────────────────────
/[Aa]ssets/[Ss]treaming[Aa]ssets/aa/

# ── Auto-generated docs ───────────────────────────────────────
ExportedObj/
.consulo/
*.cg
*.shader.generated

# ── Unity version control metadata ───────────────────────────
/[Aa]ssets/Plugins/Editor/JetBrains*

# ── Keep these ────────────────────────────────────────────────
# Assets/Scripts/        ← all C# scripts
# Assets/Editor/         ← editor scripts
# Assets/Cartography/    ← tile sprites
# Assets/Resources/      ← parchment background
# Assets/Sprites/        ← pixel platformer sprites
# Assets/Scenes/         ← scene files
# ProjectSettings/       ← required for Unity
# Packages/              ← package manifest